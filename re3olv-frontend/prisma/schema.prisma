// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RegionConfig {
  id              String   @id @default(uuid())
  countryCode     String   @unique // ISO 3166-1 alpha-2
  activeAdapters  String?  // JSON: {CREDIT: 'Experian', PAYMENTS: 'Stripe', ERP: 'SAP', BANKING: 'Plaid'}
  complianceRules String?  // JSON: {maxInterest: 15, disclosureText: '...', currency: 'MAD'}
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Organization {
  id                   String             @id @default(uuid())
  name                 String
  logoUrl              String?
  primaryColor         String             @default("#4f46e5") // indigo-600
  secondaryColor       String             @default("#0f172a") // slate-900
  legalName            String?
  supportEmail         String?
  regulatoryDisclaimer String?            @default("RE3OLV is an institutional debt facilitator. All AI interactions with Nova are recorded for quality and compliance.")
  cases                Case[]
  users                User[]
  batchUploads         BatchUpload[]
  activeProviders      ProviderRegistry[] @relation("ActiveProviders")
}

model ProviderRegistry {
  id            String         @id @default(uuid())
  countryCode   String         // ISO 3166-1 alpha-2
  category      String         // CREDIT, BUSINESS, BANKING
  providerName  String
  apiConfig     String?        // JSON string
  organizations Organization[] @relation("ActiveProviders")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model User {
  id             String       @id @default(uuid())
  name           String
  role           String       @default("AGENT") // AGENT, MANAGER
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Case {
  id               String   @id @default(uuid())
  borrowerName     String   @default("Anonymous")
  isSME            Boolean  @default(false)
  founderName      String?
  founderImpact    String?  // How business debt affects the owner's livelihood
  verificationMethod String  @default("OFFICIAL_REGISTER") // OFFICIAL_REGISTER, CASH_FLOW_PROXY, HYBRID
  lastFiscalUpdate DateTime?
  verifiedRevenue  Float    @default(0)
  principalAmount  Float    @default(0)
  paidAmount       Float    @default(0)
  totalAmount      Float
  creditScore      Int      @default(600)
  isVerified       Boolean  @default(false)
  isFeeFrozen      Boolean  @default(false)
  penaltyWaived    Float    @default(0)
  status           String   @default("OPEN")
  selectedOptionId String?
  hardshipReason   String?
  magicToken       String?  @unique
  magicLinkCreatedAt DateTime?
  viewCount        Int      @default(0)
  lastViewedAt     DateTime?
  lastNudgedAt     DateTime?
  settledAt        DateTime?
  nextFollowUp     DateTime?
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  batchUploadId    String?
  batchUpload      BatchUpload? @relation(fields: [batchUploadId], references: [id])
  actionLogs       ActionLog[]
  chatMessages     ChatMessage[]
  externalDebts    ExternalDebt[]
  incomes          Income[]
  expenses         Expense[]
  complianceAudits ComplianceAudit[]
  decisionLogs     DecisionLog[]
  encryptedData    String?  // For field-level encryption demo (Salary/Tokens)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DecisionLog {
  id              String   @id @default(uuid())
  caseId          String
  case            Case     @relation(fields: [caseId], references: [id])
  decisionType    String   // e.g., SHIELD_ACTIVATION, SETTLEMENT_OFFER
  aiConfidence    Float?
  humanReviewerId String?
  timestamp       DateTime @default(now())
}

model BatchUpload {
  id             String       @id @default(uuid())
  filename       String
  status         String       @default("PROCESSING") // PROCESSING, COMPLETED, FAILED
  totalRows      Int          @default(0)
  errorCount     Int          @default(0)
  cases          Case[]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ComplianceAudit {
  id           String   @id @default(uuid())
  caseId       String
  case         Case     @relation(fields: [caseId], references: [id])
  action       String   // e.g., SHIELD_ACTIVATION
  reasoning    String   // AI Explainability Log
  regulatoryRef String?  // e.g., FDCPA-2026-X
  createdAt    DateTime @default(now())
}

model Income {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  source    String
  amount    Float
  date      DateTime
}

model Expense {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  category  String   // HOUSING, FOOD, TRANSPORT, ENTERTAINMENT, OTHER
  amount    Float
  date      DateTime
}

model ExternalDebt {
  id           String   @id @default(uuid())
  caseId       String
  case         Case     @relation(fields: [caseId], references: [id])
  creditorName String
  amount       Float
  status       String   // CURRENT, DELINQUENT
  type         String   // CREDIT_CARD, LOAN, UTILITY
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  sender    String   // NOVA, USER, AGENT
  content   String
  createdAt DateTime @default(now())
}

model ActionLog {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  action    String   // NOVA_SHIELD_TRIGGER, MAGIC_LINK_VIEW, MANUAL_OVERRIDE
  details   String?
  createdAt DateTime @default(now())
}

model Waitlist {
  id        String   @id @default(uuid())
  email     String   @unique
  country   String
  userType  String   // e.g., FOUNDER, LENDER
  createdAt DateTime @default(now())
}
