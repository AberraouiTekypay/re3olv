// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Organization {
  id           String        @id @default(uuid())
  name         String
  cases        Case[]
  users        User[]
  batchUploads BatchUpload[]
}

model User {
  id             String       @id @default(uuid())
  name           String
  role           String       @default("AGENT") // AGENT, MANAGER
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Case {
  id               String   @id @default(uuid())
  borrowerName     String   @default("Anonymous")
  principalAmount  Float    @default(0)
  paidAmount       Float    @default(0)
  totalAmount      Float
  creditScore      Int      @default(600)
  isVerified       Boolean  @default(false)
  isFeeFrozen      Boolean  @default(false)
  penaltyWaived    Float    @default(0)
  status           String   @default("OPEN")
  selectedOptionId String?
  hardshipReason   String?
  magicToken       String?  @unique
  magicLinkCreatedAt DateTime?
  viewCount        Int      @default(0)
  lastViewedAt     DateTime?
  lastNudgedAt     DateTime?
  settledAt        DateTime?
  nextFollowUp     DateTime?
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  batchUploadId    String?
  batchUpload      BatchUpload? @relation(fields: [batchUploadId], references: [id])
  actionLogs       ActionLog[]
  chatMessages     ChatMessage[]
  externalDebts    ExternalDebt[]
  incomes          Income[]
  expenses         Expense[]
  complianceAudits ComplianceAudit[]
  encryptedData    String?  // For field-level encryption demo (Salary/Tokens)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BatchUpload {
  id             String       @id @default(uuid())
  filename       String
  status         String       @default("PROCESSING") // PROCESSING, COMPLETED, FAILED
  totalRows      Int          @default(0)
  errorCount     Int          @default(0)
  cases          Case[]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ComplianceAudit {
  id           String   @id @default(uuid())
  caseId       String
  case         Case     @relation(fields: [caseId], references: [id])
  action       String   // e.g., SHIELD_ACTIVATION
  reasoning    String   // AI Explainability Log
  regulatoryRef String?  // e.g., FDCPA-2026-X
  createdAt    DateTime @default(now())
}

model Income {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  source    String
  amount    Float
  date      DateTime
}

model Expense {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  category  String   // HOUSING, FOOD, TRANSPORT, ENTERTAINMENT, OTHER
  amount    Float
  date      DateTime
}

model ExternalDebt {
  id           String   @id @default(uuid())
  caseId       String
  case         Case     @relation(fields: [caseId], references: [id])
  creditorName String
  amount       Float
  status       String   // CURRENT, DELINQUENT
  type         String   // CREDIT_CARD, LOAN, UTILITY
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  sender    String   // NOVA, USER, AGENT
  content   String
  createdAt DateTime @default(now())
}

model ActionLog {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  action    String   // NOVA_SHIELD_TRIGGER, MAGIC_LINK_VIEW, MANUAL_OVERRIDE
  details   String?
  createdAt DateTime @default(now())
}
