// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Organization {
  id    String @id @default(uuid())
  name  String
  cases Case[]
  users User[]
}

model User {
  id             String       @id @default(uuid())
  name           String
  role           String       @default("AGENT") // AGENT, MANAGER
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Case {
  id               String   @id @default(uuid())
  borrowerName     String   @default("Anonymous")
  principalAmount  Float    @default(0)
  paidAmount       Float    @default(0)
  totalAmount      Float
  creditScore      Int      @default(600)
  isFeeFrozen      Boolean  @default(false)
  penaltyWaived    Float    @default(0)
  status           String   @default("OPEN")
  selectedOptionId String?
  hardshipReason   String?
  magicToken       String?  @unique
  magicLinkCreatedAt DateTime?
  viewCount        Int      @default(0)
  lastViewedAt     DateTime?
  settledAt        DateTime?
  nextFollowUp     DateTime?
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  actionLogs       ActionLog[]
  chatMessages     ChatMessage[]
  externalDebts    ExternalDebt[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ExternalDebt {
  id           String   @id @default(uuid())
  caseId       String
  case         Case     @relation(fields: [caseId], references: [id])
  creditorName String
  amount       Float
  status       String   // CURRENT, DELINQUENT
  type         String   // CREDIT_CARD, LOAN, UTILITY
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  sender    String   // NOVA, USER, AGENT
  content   String
  createdAt DateTime @default(now())
}

model ActionLog {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  action    String   // NOVA_SHIELD_TRIGGER, MAGIC_LINK_VIEW, MANUAL_OVERRIDE
  details   String?
  createdAt DateTime @default(now())
}
